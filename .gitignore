# =============================================================================
# dbt-mesh-platform  ·  .gitignore
# =============================================================================

# ── dbt build artifacts ───────────────────────────────────────────────────────
target/
dbt_packages/
logs/
*.log

# ── Credentials — NEVER commit ────────────────────────────────────────────────
profiles.yml
.env
*.env
*.p8
*.pub
*.pem

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.pytest_cache/
*.egg-info/
dist/
build/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── dbt Cloud ─────────────────────────────────────────────────────────────────
.dbt/
